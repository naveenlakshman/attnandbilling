# Copy this file to .env.cloudsql. Do not commit secrets.
SECRET_KEY=replace-with-a-random-secret
DB_TYPE=mysql
DB_CONNECTION_MODE=direct
MYSQL_HOST=cloud-sql-proxy
MYSQL_PORT=3306
# Cloud SQL for MySQL truncates IAM service-account names at the @ character.
MYSQL_USER=644631083795-compute
MYSQL_PASSWORD=
MYSQL_DB=attn_billing_testing
CLOUD_SQL_ENABLE_IAM_AUTH=true
CLOUD_SQL_IAM_PRINCIPAL=644631083795-compute@developer.gserviceaccount.com
DEBUG_MODE=true
SESSION_COOKIE_SECURE=false
